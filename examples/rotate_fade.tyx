#import "@preview/candy:0.1.0": *

// Candy example: a green square rotates 90° while fading to 30% opacity,
// then rotates back with there-and-back easing.
#mobject("sq", rect(width: 2cm, height: 2cm, fill: green))

#animate("sq", rotate: deg, opacity: 30%, duration: 800, easing: "cubic-in-out")
#animate("sq", rotate: deg, opacity: 100%, duration: 800, easing: "there-and-back")
