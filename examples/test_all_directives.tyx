#import "@preview/candy:0.1.0": *

#mobject("dot", circle(radius: 1cm, fill: blue))
#mobject("box", rect(width: 2cm, height: 2cm, fill: red))

#animate("dot", to: (4cm, 0pt), duration: 500, easing: "linear")
#animate("box", scale: 1.5, duration: 500, easing: "smooth")
#animate("dot", rotate: deg, duration: 500, easing: "cubic-in-out")
#animate("box", opacity: 50%, duration: 500)
#animate("dot", dx: 2cm, dy: 1cm, duration: 500)
#animate("box", scale-by: 1.2, duration: 500)
#animate("dot", rotate-by: -bydeg, duration: 500)
#pause(duration: 300)
#save-state("dot", slot: "home")
#animate("dot", to: (0cm, 0cm), duration: 500)
#restore("dot", slot: "home", duration: 500)
#indicate("box", factor: 1.3, duration: 400)
#flash("dot", factor: 2.0, duration: 300)
#wiggle("box", degrees: 15, duration: 400)
#disappear("dot")
#appear("dot")
#blink("dot", blinks: 2, duration: 600)
#spiral-in("box", scale: 2.0, rotate: deg, duration: 400)
#focus-on("dot", factor: 0.6, duration: 300)
#fade-transform("dot", "box", duration: 400)
