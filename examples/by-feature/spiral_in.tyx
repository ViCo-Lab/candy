#import "@preview/candy:0.1.0": *

// Feature: #spiral-in — docs/reference/directives.md
// Fly in from a scaled-up, rotated, invisible state to the natural position.
#scene(width: 16cm, height: 9cm, bg: white)[
  #mobject("title", text(28pt, weight: "bold", fill: blue)[Welcome])
  #spiral-in("title", scale: 2.2, rotate: 0.0, duration: 800, easing: "cubic-out")
]
