#import "@preview/candy:0.1.0": *

// Feature: #restore — docs/reference/directives.md
// Interpolate back to a previously saved state (see #save_state).
#scene(width: 16cm, height: 9cm, bg: white)[
  #mobject("dot", circle(radius: 1cm, fill: blue))
  #save-state("dot", slot: "home")
  #animate("dot", to: (4cm, 2cm), duration: 800, easing: "smooth")
  #restore("dot", slot: "home", duration: 500, easing: "cubic-in-out")
]
