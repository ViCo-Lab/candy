#import "@preview/candy:0.1.0": *

// Candy example: a red box moves to (3cm, 2cm) while scaling up to 1.5x.
// Durations are in milliseconds. Valid standard Typst.
#mobject("box", rect(width: 2cm, height: 2cm, fill: red))

#animate("box", to: (3cm, 2cm), duration: 800, easing: "cubic-out")
#animate("box", scale: 1.5, duration: 800, easing: "smooth")
